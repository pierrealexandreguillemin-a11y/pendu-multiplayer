# ISO 5055 Compliant Pre-commit Hook
# Ensures code quality before commit

echo "Running pre-commit checks..."

# 0. Check word classifications freshness (if source files changed)
if git diff --cached --name-only | grep -qE "src/lib/(words|letter-frequencies|bigram-frequencies|word-frequencies|difficulty-config)\.ts"; then
  echo "Checking word classifications freshness..."
  npm run check:classifications
fi

# 1. Run lint-staged (ESLint + Prettier on staged files)
npx lint-staged

# 2. TypeScript type checking
echo "Checking TypeScript types..."
npm run typecheck

# 3. Run tests
echo "Running tests..."
npm run test:run

echo "Pre-commit checks passed!"
